# Example environment configuration for agent-mail.
#
# Every setting can also live in a TOML config file (--config path.toml). Environment
# variables override the file. Full reference: docs/configuration.md
# The shipped src/agent_mail/defaults.toml documents every option.

# --- NATS (required) ---
NATS_URL=nats://127.0.0.1:4222
# NATS auth — set at most one style (all unset = no auth):
# NATS_TOKEN=s3cr3t
# NATS_USER=agent-mail
# NATS_PASSWORD=...
# NATS_CREDS_FILE=/run/secrets/nats.creds
# NATS_CA_FILE=/run/secrets/nats-ca.pem

# --- MCP server ---
# stdio = local, single agent (identity from AGENT_ID). http = hosted, multi-agent.
AGENT_MAIL_TRANSPORT=http
AGENT_MAIL_HOST=0.0.0.0
AGENT_MAIL_PORT=8080
AGENT_MAIL_PATH=/mcp
# AGENT_MAIL_PUBLIC_URL=https://mail.example   # advertised URL behind a proxy

# --- Hub identity & administration (advertised to agents via hub_info) ---
AGENT_MAIL_HUB=agent-mail
# AGENT_MAIL_HUB_DESCRIPTION=Homelab agent mail
# AGENT_MAIL_ADMIN_AGENT=admin
# AGENT_MAIL_ISSUE_URL=https://github.com/you/repo/issues
# AGENT_MAIL_CONTACT=ops@example.com

# --- Ops ---
AGENT_MAIL_LOG_LEVEL=INFO

# Identity is two-part: project + agent name. For the CLI or a single-agent stdio
# server, set both. Leave unset for a hosted multi-agent http server (identity comes
# from each agent's URL /<project>/<agent>/mcp instead).
# AGENT_MAIL_PROJECT=agent-mail
# AGENT_ID=claude-opus
