# Copy to .env and adjust. agent-mail reads these at startup.

# NATS server (with JetStream). Required — point at your own server.
NATS_URL=nats://127.0.0.1:4222

# --- MCP server (agent-mail mcp-serve) ---
# stdio = local, single agent (identity from AGENT_ID below).
# http  = hosted, multi-agent (identity from the URL /<agent>/mcp).
AGENT_MAIL_TRANSPORT=http
AGENT_MAIL_HOST=0.0.0.0
AGENT_MAIL_PORT=8080
AGENT_MAIL_PATH=/mcp

# Log level: DEBUG | INFO | WARNING | ERROR
AGENT_MAIL_LOG_LEVEL=INFO

# Only for the CLI or a single-agent stdio server. Leave unset for a hosted
# multi-agent http server (identity comes from each agent's URL instead).
# AGENT_ID=my-agent
